# 亚细亚内容营销系统 - 配置文件
# 请根据实际情况修改以下配置

# 服务端口
PORT=3001

# AI模型配置（支持OpenAI兼容接口，如通义千问Qwen、DeepSeek等）
# 通义千问: https://dashscope.console.aliyun.com/
AI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=your-api-key-here
AI_MODEL=qwen-plus

# 图片生成模型（可选，通义万相）
IMAGE_MODEL=wanx-v1

# 数据库
DB_PATH=./db/yaxiya.db
